{
  "name": "ClawDeck",
  "version": "0.1.0",
  "description": "OpenClaw AI Assistant plugin for Steam Deck via Decky Loader",
  "type": "module",
  "scripts": {
    "build": "shx rm -rf dist && rollup -c --silent",
    "watch": "rollup -c -w",
"package": "shx rm -rf out && npm run build && shx mkdir -p out/ClawDeck && shx cp plugin.json out/ClawDeck/ && shx cp main.py out/ClawDeck/ && shx cp -r dist out/ClawDeck/ && shx cp -r py_modules out/ClawDeck/ && shx cp -r defaults out/ClawDeck/",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ClawDeck/ClawDeck"
  },
  "keywords": [
    "decky",
    "plugin",
    "steam-deck",
    "openclaw",
    "ai-assistant"
  ],
  "author": "ClawDeck",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ClawDeck/ClawDeck/issues"
  },
  "homepage": "https://github.com/ClawDeck/ClawDeck#readme",
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-replace": "^5.0.5",
    "@rollup/plugin-typescript": "^11.1.6",
    "rollup": "^4.9.4",
    "rollup-plugin-import-css": "^3.5.0",
    "shx": "^0.3.4",
    "tslib": "^2.6.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@decky/api": "^1.1.2",
    "@decky/ui": "^4.7.2",
    "react-icons": "^5.0.1"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "react",
        "react-dom"
      ]
    }
  }
}
